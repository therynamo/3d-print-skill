# Copy to `.env` (gitignored) and fill in, OR export these in your shell.
# Shell exports always take precedence over this file.
# Auto-loaded from <repo>/.env and ~/.3dprint/.env.

# --- OctoPrint ---
OCTOPRINT_URL=http://octopi.local
OCTOPRINT_API_KEY=

# --- Printables (optional) ---
# Free models download with no auth via the site's GraphQL API. Only set this for
# gated/paid models you own: a bearer token copied from a logged-in browser
# (DevTools -> request to api.printables.com -> Authorization header, after "Bearer ").
# Sent only as an Authorization header; never printed or logged.
PRINTABLES_TOKEN=

# --- optional ---
# stl | png | both  (which preview artifact the skill hands you; default both)
PRINT3D_PREVIEW_FORMAT=both
# override the runtime data dir (DB, work files, downloads); default ~/.3dprint
# PRINT3D_HOME=
